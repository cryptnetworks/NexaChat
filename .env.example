NODE_ENV=development
NEXA_SERVER_PORT=3000
NEXA_SERVER_HOST=0.0.0.0
NEXA_SERVER_BODY_LIMIT_BYTES=16384
NEXA_SERVER_REQUEST_TIMEOUT_MS=15000
NEXA_SERVER_SHUTDOWN_TIMEOUT_MS=10000
NEXA_SERVER_RATE_LIMIT=1000
NEXA_SERVER_RATE_WINDOW_SECONDS=60
NEXA_WEB_ORIGIN=http://localhost:5173
NEXA_SECURE_COOKIES=false
NEXA_SESSION_ABSOLUTE_SECONDS=604800
NEXA_SESSION_IDLE_SECONDS=86400
NEXA_AUTH_RATE_LIMIT=10
NEXA_AUTH_RATE_WINDOW_SECONDS=60
NEXA_ARGON2_MEMORY_KIB=19456
NEXA_ARGON2_PASSES=2
NEXA_ARGON2_PARALLELISM=1
NEXA_ARGON2_TAG_LENGTH=32
NEXA_ARGON2_SALT_LENGTH=16
DATABASE_URL=postgresql://nexa:local-development-password@localhost:5432/nexa
NEXA_DATABASE_POOL_MAX=10
NEXA_DATABASE_CONNECT_TIMEOUT_MS=5000
NEXA_DATABASE_IDLE_TIMEOUT_MS=30000
NEXA_DATABASE_QUERY_TIMEOUT_MS=5000
NEXA_ENABLE_DEV_AUTH=false
NEXA_WS_MAX_CONNECTIONS=1000
NEXA_WS_MAX_CONNECTIONS_PER_ACCOUNT=5
NEXA_WS_MAX_CONNECTIONS_PER_ADDRESS=20
NEXA_WS_MAX_SUBSCRIPTIONS=32
NEXA_WS_MAX_PAYLOAD_BYTES=16384
NEXA_WS_MAX_BUFFERED_BYTES=262144
NEXA_WS_RATE_LIMIT=60
NEXA_WS_RATE_WINDOW_SECONDS=10
NEXA_WS_HEARTBEAT_SECONDS=15
NEXA_WS_STALE_SECONDS=45
NEXA_WS_REVALIDATE_SECONDS=5
NEXA_WS_DRAIN_SECONDS=5
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=nexa-local
S3_SECRET_KEY=change-this-local-secret
S3_BUCKET=nexa-attachments
S3_REGION=us-east-1
NEXA_OBJECT_STORAGE_ENABLED=false
NEXA_OBJECT_STORAGE_CREATE_BUCKET=true
NEXA_OBJECT_STORAGE_MAX_BYTES=26214400
NEXA_OBJECT_STORAGE_TIMEOUT_MS=5000
NEXA_OBJECT_STORAGE_CLEANUP_PAGE_SIZE=100
