# Copy to a host-only file outside the repository and review every value.
NEXA_COMPOSE_PROJECT_NAME=nexa-chat-production
NEXA_SECRET_DIR=/etc/nexa-chat/secrets
NEXA_PUBLIC_ORIGIN=https://chat.example.com
NEXA_HTTPS_BIND_ADDRESS=0.0.0.0
NEXA_HTTPS_PORT=443

# The trusted proxy /32 is derived from the edge address.
NEXA_FRONTEND_SUBNET=172.30.0.0/24
NEXA_EDGE_ADDRESS=172.30.0.10
NEXA_SERVER_ADDRESS=172.30.0.11
NEXA_BACKEND_SUBNET=172.31.0.0/24

# Replace all three values for every reviewed release. Do not deploy `local`,
# `latest`, a branch name, or an abbreviated revision.
NEXA_IMAGE_TAG=release-0.1.0-0123456789abcdef
NEXA_IMAGE_VERSION=0.1.0
NEXA_IMAGE_REVISION=0123456789abcdef0123456789abcdef01234567
NEXA_IMAGE_SOURCE=https://github.com/cryptnetworks/NexaChat
NEXA_LOG_LEVEL=info
NEXA_TRACE_SAMPLE_RATE=0.01
NEXA_S3_BUCKET=nexa-attachments
NEXA_S3_REGION=us-east-1

# Keep this directory and key material off the repository volume. The key ID is
# an operator label only; the key is a 32-byte-or-longer file in NEXA_SECRET_DIR.
NEXA_BACKUP_DIR=/srv/nexa-chat/backups
NEXA_BACKUP_KEY_ID=replace-with-operator-key-identifier
NEXA_BACKUP_RETENTION_DAYS=30
NEXA_BACKUP_RETENTION_COUNT=7
NEXA_BACKUP_INCOMPLETE_HOURS=24
