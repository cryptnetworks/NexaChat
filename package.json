{
  "name": "nexa-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-only",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "desktop:build": "npm run build:app --workspace @nexa/desktop",
    "desktop:dev": "npm run dev --workspace @nexa/desktop",
    "desktop:package": "npm run package --workspace @nexa/desktop",
    "dev": "npm run dev --workspace @nexa/server & npm run dev --workspace @nexa/web",
    "dev:up": "bash scripts/dev-up.sh",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "migrate": "npm run migrate --workspace @nexa/server",
    "release:artifacts": "tsx tools/release/artifact-bundle.ts",
    "release:candidate": "tsx tools/release/candidate.ts",
    "release:check": "tsx tools/release/versioning.ts check",
    "release:prepare": "tsx tools/release/versioning.ts prepare",
    "release:sbom": "tsx tools/release/sbom.ts",
    "release:upgrade": "tsx tools/release/upgrade.ts",
    "release:upgrade:database": "npm run upgrade:database:plan --workspace @nexa/server",
    "test": "vitest run",
    "test:auth": "vitest run packages/auth/test apps/server/test/config.test.ts apps/server/test/auth.integration.test.ts",
    "test:authorization": "vitest run packages/authorization/test apps/server/test/authorization.integration.test.ts",
    "test:architecture": "tsc -p tools/architecture/tsconfig.json && vitest run tools/architecture/check.test.ts",
    "test:config": "vitest run apps/server/test/config.test.ts",
    "test:contracts": "vitest run packages/api-contracts/src/error-contract.test.ts packages/realtime-contracts/src/contracts.test.ts packages/realtime-contracts/src/compatibility-fixtures.test.ts",
    "test:coordination": "vitest run packages/coordination/test",
    "test:desktop": "vitest run apps/desktop/test",
    "test:http": "vitest run apps/server/test/http.integration.test.ts apps/server/test/community-lifecycle.integration.test.ts",
    "test:object-storage": "vitest run packages/object-storage/test",
    "test:performance": "tsx tools/performance/api-benchmark.ts --profile=ci",
    "test:performance:postgres": "tsx tools/performance/api-benchmark.ts --profile=postgres",
    "test:performance:unit": "vitest run tools/performance/*.test.ts",
    "test:postgres": "vitest run packages/postgres/test apps/server/test/postgres.integration.test.ts",
    "test:realtime-capacity": "tsx tools/performance/realtime-capacity.ts --profile=ci --coordination=local",
    "test:realtime-capacity:valkey": "tsx tools/performance/realtime-capacity.ts --profile=ci --coordination=valkey",
    "test:realtime-soak": "tsx tools/performance/realtime-capacity.ts --profile=soak --coordination=valkey",
    "test:resilience": "vitest run packages/object-storage/test packages/domain/test/job-recovery.test.ts",
    "test:resilience:integration": "vitest run packages/postgres/test/postgres.integration.test.ts packages/object-storage/test/object-storage.test.ts",
    "test:unit": "vitest run packages/domain/test",
    "test:websocket": "vitest run apps/server/test/websocket.integration.test.ts",
    "typecheck": "npm run typecheck --workspaces --if-present && tsc --noEmit -p tools/performance/tsconfig.json && tsc --noEmit -p tools/release/tsconfig.json",
    "verify:clean-env": "bash scripts/verify-clean-environment.sh"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tauri-apps/cli": "2.11.4",
    "@types/node": "26.1.1",
    "@types/ws": "8.18.1",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "typescript": "5.8.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
