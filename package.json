{
  "name": "nexa-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-only",
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace @nexa/server & npm run dev --workspace @nexa/web",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "migrate": "npm run migrate --workspace @nexa/server",
    "test": "vitest run",
    "test:http": "vitest run apps/server/test/http.integration.test.ts",
    "test:postgres": "vitest run packages/postgres/test apps/server/test/postgres.integration.test.ts",
    "test:unit": "vitest run packages/domain/test",
    "test:websocket": "vitest run apps/server/test/websocket.integration.test.ts",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "9.31.0",
    "@types/node": "24.0.15",
    "@types/ws": "8.18.1",
    "eslint": "9.31.0",
    "prettier": "3.6.2",
    "typescript": "5.8.3",
    "typescript-eslint": "8.38.0",
    "vitest": "3.2.7"
  }
}
